# Thai Receipt Generator Configuration
# Copy this file to .env and adjust as needed.
# All values below are defaults — uncomment and change to override.

# Comma-separated item counts to generate
RECEIPT_ITEMS=1,2,3

# Comma-separated template names: formal_invoice, simple_receipt, thermal_pos
RECEIPT_TEMPLATES=formal_invoice,simple_receipt,thermal_pos

# Max number of combinations to sample (leave empty for all)
RECEIPT_MAX_COMBOS=50

# Random seed for reproducible sampling
RECEIPT_SEED=42

# Output directory for generated images
RECEIPT_OUTPUT_DIR=output

# Rendering DPI
RECEIPT_DPI=150

# Disable variation axes (set to "true" to disable)
RECEIPT_NO_PER_ITEM_VAT=false
RECEIPT_NO_PER_ITEM_WHT=false
RECEIPT_NO_PER_ITEM_DISCOUNT=false
RECEIPT_NO_STANDALONE_DISCOUNT=false
RECEIPT_NO_OVERALL_DISCOUNT=false
RECEIPT_NO_OVERALL_VAT=false
RECEIPT_NO_OVERALL_WHT=false
