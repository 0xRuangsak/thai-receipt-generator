# Thai Receipt Generator Configuration
# Copy to .env and adjust. CLI flags override these values.

# ── General ──────────────────────────────────────
RECEIPT_JSON_DIR=generated_json    # where gen-json writes JSON configs
RECEIPT_OUTPUT_DIR=output          # where render writes PNG images
RECEIPT_DPI=150                    # image resolution (150 = good for OCR)

# ── Batch generation (thai-receipt-gen gen-json) ─
RECEIPT_ITEMS=1,2,3                # receipt variations with 1, 2, and 3 items
RECEIPT_TEMPLATES=formal_invoice,simple_receipt,thermal_pos
RECEIPT_MAX_COMBOS=50              # sample 50 from all combinations (remove for all ~11k)
RECEIPT_SEED=42                    # same seed = same samples every time

# ── Disable variation axes (set to true to turn OFF) ─
RECEIPT_NO_PER_ITEM_VAT=false      # per-item VAT 7%
RECEIPT_NO_PER_ITEM_WHT=false      # per-item withholding tax
RECEIPT_NO_PER_ITEM_DISCOUNT=false # per-item discount (absolute/percentage)
RECEIPT_NO_STANDALONE_DISCOUNT=false # standalone discount rows
RECEIPT_NO_OVERALL_DISCOUNT=false  # overall receipt discount
RECEIPT_NO_OVERALL_VAT=false       # overall VAT on entire receipt
RECEIPT_NO_OVERALL_WHT=false       # overall WHT on entire receipt
